APP_NAME=Codigo do Destino API
APP_VERSION=2.2.0
ENGINE_VERSION=engine-2.2.0
ENVIRONMENT=development
DEBUG=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/astrologia
REDIS_URL=redis://localhost:6379/0

MAP_CACHE_TTL=604800
COMPUTED_CACHE_TTL=7776000
EPHEMERIS_CACHE_TTL=15552000
LLM_CACHE_TTL=2592000
LOCAL_CACHE_TTL_SECONDS=20
CACHE_TTL_JITTER_SECONDS=90
REDIS_SOCKET_TIMEOUT_SECONDS=2
AUTO_CREATE_SCHEMA=true

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

SWISSEPH_PATH=./ephe

MAX_EVENTS_IN_RESPONSE=6
MAX_EVENTS_IN_PROMPT=3
LLM_COMPLEXITY_THRESHOLD=0.55
LLM_MIN_HIGH_INTENSITY_EVENTS=1
LLM_MAX_TOKENS=320
LLM_FORCE_FOR_MASTER_NUMBERS=true

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v3.2
OPENROUTER_SITE_URL=https://codigododestino.local
OPENROUTER_APP_NAME=CodigodoDestino
